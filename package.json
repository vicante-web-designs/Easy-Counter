{
    "name": "easycounter",
    "version": "1.0.0",
    "private": true,
    "description": "Church attendance counter — LAN desktop app",
    "main": "electron/main.js",
    "workspaces": [
        "app/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently -n SERVER,CLIENT,ELECTRON -c green,blue,yellow \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:electron\"",
        "dev:server": "cd app/server && npm run dev",
        "dev:client": "cd app/client && npm run dev",
        "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
        "build:electron": "esbuild electron/main.ts --bundle --platform=node --target=node18 --external:electron --format=cjs --outfile=electron/main.js",
        "build": "npm run build:client && npm run build:server",
        "build:client": "cd app/client && npm run build",
        "build:server": "cd app/server && npm run build",
        "package": "npm run build && electron-builder"
    },
    "build": {
        "appId": "com.easycounter.app",
        "productName": "EasyCounter",
        "directories": {
            "output": "release"
        },
        "files": [
            "electron/**/*",
            "app/server/dist/**/*",
            "app/client/dist/**/*",
            "app/data/**/*",
            "node_modules/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "assets/icon.icns"
        }
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^42.0.1",
        "electron-builder": "^26.8.1",
        "esbuild": "^0.28.0",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "wait-on": "^9.0.5"
    },
    "dependencies": {
        "axios": "^1.15.0"
    }
}
