{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["jest", "node"],
    "isolatedModules": true,
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "src/__tests__"],
  "references": [
    { "path": "./tsconfig.test.json" }
  ]
}
